# QQ官方机器人配置示例
# 将此文件复制为 .env 并填写你的实际值

# ==================== 基础配置 ====================
QQ_ENABLE=true

# ==================== 机器人类型选择 ====================
# 'official' = QQ官方机器人（需要AppID和Token）
# 'go-cqhttp' = 第三方框架（需要本地运行go-cqhttp）
QQ_BOT_TYPE=official

# ==================== QQ官方机器人配置 ====================
# 从QQ开放平台获取：https://bot.q.qq.com
QQ_APP_ID=your_app_id_here
QQ_TOKEN=your_token_here

# 沙箱环境（测试时使用）
QQ_SANDBOX=false

# ==================== 推送目标配置 ====================
# 格式：类型:ID,类型:ID
# 私聊：user:OPENID
# 群聊：group:GROUP_ID
QQ_TARGETS=user:YOUR_OPENID

# ==================== 事件过滤 ====================
# 只推送这些类型的事件（逗号分隔）
QQ_ENABLED_EVENTS=complete,error,phase

# ==================== IM Bridge 配置 ====================
IM_BRIDGE_PORT=18080
