# Feishu Bot Configuration
# 飞书机器人配置示例

# ==================== 基础配置 ====================
# 启用飞书通知
FEISHU_ENABLE=true

# 使用飞书平台
IM_PLATFORM=feishu

# ==================== 飞书Webhook配置 ====================
# 从飞书群设置中获取Webhook URL
# 获取方法：
#   1. 打开飞书群聊
#   2. 点击群设置 → 群机器人 → 添加机器人
#   3. 选择"自定义机器人"
#   4. 复制Webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 事件过滤 ====================
# 只推送这些类型的事件（逗号分隔）
FEISHU_ENABLED_EVENTS=complete,error,phase

# ==================== IM Bridge 配置 ====================
IM_BRIDGE_PORT=18080
