# DeepSeek API Configuration
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# OpenCode Server Configuration
# ✅ 修复：配置Basic认证以连接OpenCode Server CLI（4096端口）
# ⚠️ 重要：生产环境请使用强密码，不要使用默认值
OPENCODE_SERVER_URL=http://127.0.0.1:4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=your_secure_password_here

# Display Settings
SCREEN_WIDTH=1280
SCREEN_HEIGHT=720
DISPLAY=:0

# Preview Task Configuration
# Preview任务超时时间（秒）
# 默认：不设置（让任务自然完成）
# 留空或设置为0 = 不限制（推荐）
# 设置具体值 = 强制超时（不推荐，除非特殊场景）
#
# 说明：
# - Preview任务的执行时间是可预测的（基于文件大小和打字机效果）
# - 默认不设置超时，让所有preview事件正常发送
# - 只有在特殊场景下才需要设置超时（如测试环境）
# 更详细的配置说明请参考：PREVIEW_TIMEOUT_CONFIG.md
# PREVIEW_TASK_TIMEOUT=
