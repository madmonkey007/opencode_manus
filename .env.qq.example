# OpenCode QQ Bot集成配置示例
# 复制此文件为 .env.qq 并根据实际情况修改

# ============================================================================
# QQ Bot配置
# ============================================================================

# 启用QQ Bot (true/false)
QQ_ENABLE=true

# go-cqhttp API地址 (默认: http://localhost:3000)
QQ_API_URL=http://localhost:3000

# 访问令牌 (可选，如go-cqhttp配置了token)
QQ_ACCESS_TOKEN=

# QQ Bot平台 (go-cqhttp, shamrock, napcat)
QQ_PLATFORM=go-cqhttp

# ============================================================================
# 推送目标配置
# ============================================================================

# 推送目标列表 (多个目标用逗号分隔)
# 格式: type:id
#   - user:123456  → 发送私聊给QQ号123456
#   - group:789     → 发送群消息到群号789
QQ_TARGETS=user:123456,group:789

# ============================================================================
# 事件过滤配置
# ============================================================================

# 推送的事件类型 (多个用逗号分隔)
# 可选: complete, error, phase, action, progress
QQ_ENABLED_EVENTS=complete,error,phase

# ============================================================================
# 消息格式配置
# ============================================================================

# 消息前缀
QQ_MESSAGE_PREFIX="[OpenCode] "

# 是否显示详细信息 (true/false)
QQ_SHOW_DETAIL=true

# ============================================================================
# 其他配置
# ============================================================================

# 发送超时时间 (秒)
QQ_TIMEOUT=5

# 失败重试次数
QQ_MAX_RETRY=3

# ============================================================================
# 示例配置
# ============================================================================

# 示例1: 发送到自己的QQ
# QQ_ENABLE=true
# QQ_TARGETS=user:123456789

# 示例2: 发送到多个群
# QQ_ENABLE=true
# QQ_TARGETS=group:111,group:222,group:333

# 示例3: 只推送完成和失败事件
# QQ_ENABLE=true
# QQ_ENABLED_EVENTS=complete,error

# 示例4: 发送到私聊和群
# QQ_ENABLE=true
# QQ_TARGETS=user:123456,group:789
