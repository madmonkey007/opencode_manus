# Feishu Bot Configuration
# Generated: 2026-03-14

# Enable Feishu notifications
FEISHU_ENABLE=true

# Use Feishu platform
IM_PLATFORM=feishu

# Feishu Webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/899e8328-4975-4241-86e1-2c3837b3a313

# Keyword for message verification
FEISHU_KEYWORD=opencode

# Event types to forward
FEISHU_ENABLED_EVENTS=complete,error,phase

# IM Bridge server port
IM_BRIDGE_PORT=18080
